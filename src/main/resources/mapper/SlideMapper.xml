<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.staitech.fr.mapper.SlideMapper">

    <resultMap id="BaseResultMap" type="cn.staitech.fr.domain.Slide">
        <id property="slideId" column="slide_id" jdbcType="BIGINT"/>
        <result property="projectId" column="special_id" jdbcType="BIGINT"/>
        <result property="imageId" column="image_id" jdbcType="BIGINT"/>
        <result property="createBy" column="create_by" jdbcType="BIGINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateBy" column="update_by" jdbcType="BIGINT"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>
    <resultMap id="SlidePageVoMap" type="cn.staitech.fr.vo.project.slide.SlidePageVo">
        <id property="slideId" column="slide_id"/>
        <result property="thumbUrl" column="thumb_url"/>
        <result property="fileName" column="image_name"/>
        <result property="groupCode" column="group_code"/>
        <result property="waxCode" column="wax_code"/>
        <result property="animalCode" column="animal_code"/>
        <result property="genderFlag" column="sex_flag"/>
        <result property="createUser" column="user_name"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="imagePath" column="image_path"/>
        <result property="format" column="format"/>
        <result property="width" column="width"/>
        <result property="height" column="height"/>
        <result property="resolutionX" column="resolution_x"/>
        <result property="resolutionY" column="resolution_y"/>
        <result property="sourceLens" column="source_lens"/>
        <result property="imageId" column="image_id"/>
        <result property="imageName" column="image_name"/>
        <result property="isView" column="is_view"/>
        <result property="viewers" column="viewers"
                 typeHandler="cn.staitech.fr.mapper.handler.ListLongTypeHandler"
                 javaType="java.util.List"/>
    </resultMap>

    <resultMap id="SlideDetailVoMap" type="cn.staitech.fr.vo.project.slide.SlideDetailVo">
        <!-- 主键 -->
        <id property="slideId" column="slide_id"/>

        <!-- 基础字段 -->
        <result property="description" column="description"/>
        <result property="imageId" column="image_id"/>
        <result property="imageName" column="image_name"/>
        <result property="groupName" column="group_code"/>
        <result property="gender" column="sex_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="topicId" column="topic_id"/>
        <result property="topicName" column="topic_name"/>
        <result property="status" column="status"/>
        <result property="deleteFlag" column="del_flag"/>
        <result property="imagePath" column="image_path"/>
        <result property="thumbUrl" column="thumb_url"/>
        <result property="format" column="format"/>
        <result property="width" column="width"/>
        <result property="height" column="height"/>
        <result property="resolutionX" column="resolution_x"/>
        <result property="resolutionY" column="resolution_y"/>
        <result property="sourceLens" column="source_lens"/>

        <!-- JSON 字段：需要指定 JacksonTypeHandler 解析为 List<Long> -->
        <result property="viewers" column="viewers"
                 typeHandler="cn.staitech.fr.mapper.handler.ListLongTypeHandler"
                 javaType="java.util.List"/>
</resultMap>

    <select id="selectBySpecialId" parameterType="java.lang.Long" resultType="java.lang.String">
        select tt.topic_name
        from fr_special fsl
                 left join tb_topic tt on fsl.topic_id = tt.topic_id
        where special_id = #{specialId}
    </select>
    
    <sql id = "slideList">
        select ti.thumb_url,
        ti.image_name fileName,
        ti.image_path,
        ti.format,
        ti.width,
        ti.height,
        ti.resolution_x,
        ti.resolution_y,
        ti.source_lens,
        ti.image_id,
        ti.image_name,
        ti.group_code,
        ti.wax_code,
        ti.animal_code,
        ti.sex_flag,
        ti.topic_name,
        su.nick_name as user_name,
        fs.create_time,
        fs.description,
        fs.slide_id,
        ${params.currentUserId} as is_view,
        fs.viewers
        from fr_slide fs
        left join tb_image ti on fs.image_id = ti.image_id
        left join sys_user su on fs.create_by = su.user_id
        <where>
            fs.special_id = #{params.projectId}
            and fs.del_flag='0'
            <if test="params.fileName != null and params.fileName != ''">
                and ti.image_name like concat('%',#{params.fileName},'%')
            </if>
            <if test="params.animalCode != null and params.animalCode != ''">
                and ti.animal_code like concat('%',#{params.animalCode},'%')
            </if>
            <if test="params.description != null and params.description != ''">
                and fs.description like concat('%',#{params.description},'%')
            </if>
            <if test="params.genderFlag != null and params.genderFlag != ''">
                and ti.sex_flag = #{params.genderFlag}
            </if>
            <if test="params.isView != null">
                <if test="params.isView">
                    and ${params.currentUserId}
                </if>
                <if test="!params.isView">
                    and not ${params.currentUserId}
                </if>
            </if>
            <if test="params.groupCode != null and params.groupCode != ''">
                and ti.group_code = #{params.groupCode}
            </if>
            <if test="params.waxCode != null and params.waxCode != ''">
                <!--  and ti.wax_code like concat('%',#{waxCode},'%') -->
                and ti.wax_code =  #{params.waxCode}
            </if>
            <if test="params.createBy != null and params.createBy != ''">
                and su.user_name like concat('%',#{params.createBy},'%')
            </if>
            <if test="params.createTimeParams!=null">
                <if test="params.createTimeParams.beginTime != null "><!-- 开始时间检索 -->
                    AND date_format(fs.create_time,'%Y%m%d') &gt;= date_format(#{params.createTimeParams.beginTime},'%Y%m%d')
                </if>
                <if test="params.createTimeParams.endTime != null "><!-- 结束时间检索 -->
                    AND date_format(fs.create_time,'%Y%m%d') &lt;= date_format(#{params.createTimeParams.endTime},'%Y%m%d')
                </if>
            </if>
        </where>
        <if test="params.sortField != null and params.sortField!=''">
            order by ${params.sortField} ${params.sortType}
        </if>
        <!-- 阅片列表排序规则：
         1、根据切片编号由小到大排序，切片编号前几位是项目号是一样，
         2、之后是动物号，动物号前几位相同，从不同的数字开始由小到大排序。
         3、如果是相同动物号的图片则根据蜡块编号由小到大再排 -->
        <if test="params.sortField == null or params.sortField==''">
            order by ti.animal_code asc,ti.wax_code asc,ti.group_code asc,ti.sex_flag asc
        </if>
    </sql>

    <select id="slideListQuery" parameterType="cn.staitech.fr.vo.project.slide.SlidePageReq"
            resultMap="SlidePageVoMap">
        <include refid="slideList"/>
    </select>

    <select id="page" parameterType="cn.staitech.fr.vo.project.slide.SlidePageReq"
            resultMap="SlidePageVoMap">
        <include refid="slideList"/>
    </select>

    <select id="slideQueryBy" parameterType="long"
            resultType="cn.staitech.fr.vo.project.slide.SlidePageVo">
        select ti.thumb_url,
        ti.image_name fileName,
        ti.group_code,
        ti.wax_code,
        ti.animal_code,
        ti.sex_flag gender_flag,
        su.user_name createUser,
        fs.create_time,
        fs.description,
        fs.slide_id
        from fr_slide fs
        left join tb_image ti on fs.image_id = ti.image_id
        left join sys_user su on fs.create_by = su.user_id
        where fs.slide_id = #{slideId}
    </select>
    

    <select id="selectListByWax" resultType="cn.staitech.fr.domain.Slide">
        select fs.slide_id,t2.wax_code
        from fr_slide fs
          left join fr_special fsl on fs.special_id = fsl.special_id
          left join tb_image t2 on fs.image_id = t2.image_id 
        where fsl.topic_id= #{topicId}
          and fsl.species_id= #{speciesId}
          and fsl.del_flag='0'
    </select>
    

    <select id="getSlideInfo" parameterType="long"
            resultMap="SlideDetailVoMap">
        select 
        s.slide_id,
        s.special_id,
        s.image_id,
        m.status,
        m.group_code,
        m.wax_code,
        m.animal_code,
        m.sex_flag,
        s.description,
        s.del_flag,
        s.create_by,
        s.create_time,
        s.update_by,
        s.update_time,
        m.image_id,
        m.thumb_url,
        m.image_path,
        m.format,
        m.width,
        m.height,
        m.resolution_x,
        m.resolution_y,
        m.source_lens,
        m.image_path,
        m.thumb_url,
        m.image_name,
        m.topic_id,
        m.topic_name,
        s.viewers
        from fr_slide s
        left join tb_image m on m.image_id = s.image_id
        <where>
            <if test="slideId != null">
                s.slide_id = #{slideId, jdbcType=NUMERIC}
            </if>
        </where>
    </select>

</mapper>
