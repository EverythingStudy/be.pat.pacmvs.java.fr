<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.staitech.fr.mapper.SpecialMemberMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.staitech.fr.domain.SpecialMember">
        <id column="member_id" property="memberId"/>
        <result column="user_id" property="userId"/>
        <result column="special_id" property="specialId"/>
        <result column="organization_id" property="organizationId"/>
        <result column="create_by" property="createBy"/>
        <result column="del_flag" property="delFlag"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        member_id
        , user_id, special_id, organization_id, create_by, del_flag, create_time, update_by, update_time
    </sql>

    <select id="getSpecialMemberList" parameterType="cn.staitech.fr.domain.in.SpecialMemberSelectIn"
            resultType="cn.staitech.fr.domain.out.SpecialMemberSelectOut">
        select sm.member_id,sm.user_id,su.user_name,su.nick_name, su.sex, su.phonenumber
        from fr_special_member sm
        left join sys_user su on sm.create_by = su.user_id
        left join sys_user_role sur on su.user_id = sur.user_id
        <where>
            sm.del_flag ='0'
        and sm.special_id = #{specialId}
        <if test="userName != null and userName != ''">
            and su.userName like concat('%', #{userName}, '%')
        </if>
        <if test="nickName != null and nickName != ''">
            and su.nick_name like concat('%', #{nickName}, '%')
        </if>
        <if test="sex != null and sex != ''">
            and su.sex = #{sex}
        </if>
        <if test="roleId != null and roleId != ''">
            and sur.role_id = #{roleId}
        </if>
        </where>
        group by (sm.member_id)
        order by sm.create_time desc

    </select>
</mapper>
