# feign 配置
feign:
  sentinel:
    enabled: false
  okhttp:
    enabled: false
  httpclient:
    enabled: false
  client:
    config:
      default:
        connectTimeout: 10000
        readTimeout: 10000
  compression:
    request:
      enabled: false
    response:
      enabled: false

